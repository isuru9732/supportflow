# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

# --- Database ---
POSTGRES_DB=supportflow
POSTGRES_USER=supportflow
POSTGRES_PASSWORD=localdevpassword
DB_URL=jdbc:postgresql://localhost:5432/supportflow

# --- JWT ---
JWT_SIGNING_KEY=replace-with-a-long-random-string-min-32-chars

# --- AI Provider (Doc 07 §5) ---
# local dev: ollama | staging/demo: gemini
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
GEMINI_API_KEY=

# --- Email (Notification Service) ---
EMAIL_PROVIDER_API_KEY=

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
